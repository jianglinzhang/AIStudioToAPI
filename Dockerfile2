FROM node:20-slim

WORKDIR /app

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    NODE_ENV=production \
    PORT=7860 \
    HOME=/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    unzip \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libxss1 \
    libxtst6 \
    xvfb \
    x11vnc \
    websockify \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/iBUHub/AIStudioToAPI.git .

RUN npm pkg delete scripts.prepare \
 && NODE_ENV=development npm install --include=dev --no-audit --no-fund \
 && NODE_ENV=development npm install --include=dev vite @vitejs/plugin-vue --no-audit --no-fund \
 && NODE_ENV=development npm run build:ui

# RUN HUSKY=0 npm install --no-audit --no-fund

# RUN npm run build:ui

ARG CAMOUFOX_URL
RUN ARCH=$(uname -m) && \
    if [ -z "$CAMOUFOX_URL" ]; then \
      if [ "$ARCH" = "x86_64" ]; then \
        CAMOUFOX_URL="https://github.com/daijro/camoufox/releases/download/v135.0.1-beta.24/camoufox-135.0.1-beta.24-lin.x86_64.zip"; \
      elif [ "$ARCH" = "aarch64" ]; then \
        CAMOUFOX_URL="https://github.com/daijro/camoufox/releases/download/v135.0.1-beta.24/camoufox-135.0.1-beta.24-lin.arm64.zip"; \
      fi; \
    fi && \
    echo "Downloading from: ${CAMOUFOX_URL}" && \
    mkdir -p /app/camoufox-linux && \
    curl -fL --retry 3 ${CAMOUFOX_URL} -o camoufox.zip && \
    unzip -q camoufox.zip -d /tmp/cf && \
    if [ -f /tmp/cf/camoufox ]; then \
        mv /tmp/cf/* /app/camoufox-linux/; \
    else \
        mv /tmp/cf/*/* /app/camoufox-linux/; \
    fi && \
    rm -rf /tmp/cf camoufox.zip && \
    chmod +x /app/camoufox-linux/camoufox

RUN chown -R 1000:0 /app && chmod -R 775 /app
USER 1000

ENV CAMOUFOX_EXECUTABLE_PATH=/app/camoufox-linux/camoufox

EXPOSE 7860

CMD ["node", "main.js"]
